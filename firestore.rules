rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isNotBlocked(uid) {
      return !exists(/databases/$(database)/documents/blocks/$(request.auth.uid + '_' + uid))
        && !exists(/databases/$(database)/documents/blocks/$(uid + '_' + request.auth.uid));
    }

    // Safely check pause — only if user doc exists (avoids permission-denied on new users)
    function isAccountActive() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(ref)
        || !('pauseUntil' in get(ref).data)
        || get(ref).data.pauseUntil == null
        || get(ref).data.pauseUntil < request.time;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any signed-in user can read profiles (needed for friend search)
      allow read: if isSignedIn();

      // Owner can create their own profile (on first sign-in)
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid;

      // Owner can update (but not change uid/email)
      allow update: if isOwner(uid);

      allow delete: if false;
    }

    // ─── Friendships ─────────────────────────────────────────────────────────
    match /friendships/{friendshipId} {
      allow read: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      allow delete: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    // ─── Blocks ──────────────────────────────────────────────────────────────
    match /blocks/{blockId} {
      allow read: if isSignedIn()
        && (resource.data.blockerId == request.auth.uid
            || resource.data.blockedId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.blockerId == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.blockerId == request.auth.uid;

      allow update: if false;
    }

    // ─── Conversations ────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create, update: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow delete: if false;
    }

    // ─── Messages ─────────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;

      allow update: if isSignedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid);

      allow delete: if false;
    }

    // ─── Calls (signaling only) ───────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isSignedIn()
        && (resource.data.callerId == request.auth.uid
            || resource.data.calleeId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.callerId == request.auth.uid;

      allow update: if isSignedIn()
        && (resource.data.callerId == request.auth.uid
            || resource.data.calleeId == request.auth.uid);

      allow delete: if false;
    }

    // ─── Deny all else ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
